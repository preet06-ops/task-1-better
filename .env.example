# Copy this file to .env and fill values
# SMTP configuration for Nodemailer
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=your-smtp-password

# From address used in emails (defaults to SMTP_USER)
FROM_EMAIL=notify@yourdomain.example

# Owner email (notifications go here). Defaults to preetham.b099@gmail.com
OWNER_EMAIL=preetham.b099@gmail.com

# Server port
PORT=3000
